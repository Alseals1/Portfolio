---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Alandis Seals — Full Stack Engineer",
  description = "I build web apps and APIs that help businesses grow. AWS Certified. 4+ years shipping real products.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

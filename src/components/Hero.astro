---
---

<section class="relative flex min-h-screen flex-col items-center justify-center px-6 pt-20 text-center">
  <!-- subtle grid background -->
  <div
    class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:40px_40px]"
  >
  </div>

  <!-- glow blob -->
  <div
    class="pointer-events-none absolute top-1/3 left-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-indigo-600/15 blur-3xl"
  >
  </div>

  <div class="relative z-10 max-w-3xl">
    <!-- social proof badge -->
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-sm text-gray-400"
    >
      <span class="h-2 w-2 rounded-full bg-green-400"></span>
      Available for freelance projects
    </div>

    <h1 class="mb-6 text-5xl font-bold leading-tight tracking-tight text-white md:text-6xl lg:text-7xl">
      I build web apps that
      <span class="text-indigo-400"> grow your business</span>
    </h1>

    <p class="mb-4 text-lg text-gray-400 md:text-xl">
      Full Stack Engineer with 4+ years shipping production apps — React,
      Node.js, TypeScript, and AWS. I take ideas from concept to deployed
      product.
    </p>

    <!-- trust signals -->
    <div class="mb-10 flex flex-wrap justify-center gap-4 text-sm text-gray-500">
      <span>AWS Certified Solutions Architect</span>
      <span class="text-white/20">·</span>
      <span>4+ Years Experience</span>
      <span class="text-white/20">·</span>
      <span>Ships Fast</span>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="#projects"
        class="w-full rounded-lg bg-indigo-600 px-8 py-3 text-base font-medium text-white transition-colors hover:bg-indigo-500 sm:w-auto"
      >
        View My Work
      </a>
      <a
        href="#contact"
        class="w-full rounded-lg border border-white/10 bg-white/5 px-8 py-3 text-base font-medium text-white transition-colors hover:bg-white/10 sm:w-auto"
      >
        Let's Talk
      </a>
    </div>

    <!-- social links -->
    <div class="mt-12 flex justify-center gap-6 text-sm text-gray-500">
      <a
        href="https://github.com/Alseals1"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-white"
      >
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/alandisseals"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-white"
      >
        LinkedIn
      </a>
      <a
        href="/resume.pdf"
        target="_blank"
        class="transition-colors hover:text-white"
      >
        Resume
      </a>
    </div>
  </div>
</section>

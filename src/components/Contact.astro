---
// Replace YOUR_FORMSPREE_ID with your form ID from formspree.io (free account)
// e.g. if your endpoint is https://formspree.io/f/xpzgkdqw, the ID is xpzgkdqw
const FORMSPREE_ID = "mjgjzwdk";
---

<section id="contact" class="py-24 px-6 border-t border-white/5">
  <div class="mx-auto max-w-2xl">
    <!-- heading -->
    <div class="mb-12 text-center">
      <p
        class="mb-3 text-sm font-medium uppercase tracking-widest text-indigo-400"
      >
        Work together
      </p>
      <h2 class="text-4xl font-bold text-white">Let's Talk</h2>
      <p class="mt-4 text-gray-400">
        Tell me about your project and I'll get back to you within 24 hours.
      </p>
    </div>

    <!-- form -->
    <form
      action={`https://formspree.io/f/${FORMSPREE_ID}`}
      method="POST"
      class="space-y-5"
    >
      <!-- name + email row -->
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label
            for="name"
            class="mb-2 block text-sm font-medium text-gray-400"
          >
            Name
          </label>
          <input
            id="name"
            type="text"
            name="name"
            required
            placeholder="Jane Smith"
            class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-gray-600 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
          />
        </div>
        <div>
          <label
            for="email"
            class="mb-2 block text-sm font-medium text-gray-400"
          >
            Email
          </label>
          <input
            id="email"
            type="email"
            name="email"
            required
            placeholder="jane@company.com"
            class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-gray-600 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
          />
        </div>
      </div>

      <!-- project type -->
      <div>
        <label
          for="project_type"
          class="mb-2 block text-sm font-medium text-gray-400"
        >
          What do you need?
        </label>
        <select
          id="project_type"
          name="project_type"
          required
          class="w-full rounded-lg border border-white/10 bg-[#0d1117] px-4 py-3 text-sm text-white outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
        >
          <option value="" disabled selected>Select a service...</option>
          <option value="web_app">Web App Development</option>
          <option value="api_backend">API & Backend Systems</option>
          <option value="cloud_infra">Cloud Infrastructure</option>
          <option value="mobile_app">Mobile App (iOS)</option>
          <option value="other">Something else</option>
        </select>
      </div>

      <!-- budget -->
      <div>
        <label
          for="budget"
          class="mb-2 block text-sm font-medium text-gray-400"
        >
          Budget range
        </label>
        <select
          id="budget"
          name="budget"
          class="w-full rounded-lg border border-white/10 bg-[#0d1117] px-4 py-3 text-sm text-white outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
        >
          <option value="" disabled selected>Select a range...</option>
          <option value="under_1k">Under $1,000</option>
          <option value="1k_5k">$1,000 – $5,000</option>
          <option value="5k_10k">$5,000 – $10,000</option>
          <option value="10k_plus">$10,000+</option>
          <option value="not_sure">Not sure yet</option>
        </select>
      </div>

      <!-- message -->
      <div>
        <label
          for="message"
          class="mb-2 block text-sm font-medium text-gray-400"
        >
          Tell me about your project
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          placeholder="What are you building? What's the timeline? Any specific requirements?"
          class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-gray-600 outline-none transition focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full rounded-lg bg-indigo-600 px-6 py-3.5 text-sm font-medium text-white transition-colors hover:bg-indigo-500"
      >
        Send message →
      </button>
    </form>

    <!-- alternate contact -->
    <p class="mt-8 text-center text-sm text-gray-500">
      Prefer email?{" "}
      <a
        href="mailto:1seals.alandis@gmail.com"
        class="text-indigo-400 transition-colors hover:text-indigo-300"
      >
        1seals.alandis@gmail.com
      </a>
    </p>
  </div>
</section>

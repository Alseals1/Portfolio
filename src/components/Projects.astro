---
import { projects } from "../data/projects";
---

<section id="projects" class="py-24 px-6">
  <div class="mx-auto max-w-6xl">
    <!-- heading -->
    <div class="mb-16 text-center">
      <p class="mb-3 text-sm font-medium uppercase tracking-widest text-indigo-400">
        Proof of work
      </p>
      <h2 class="text-4xl font-bold text-white">Featured Projects</h2>
      <p class="mt-4 text-gray-400">
        Real products, shipped to real users.
      </p>
    </div>

    <!-- project cards -->
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        projects
          .filter((p) => p.featured)
          .map((project) => (
            <article class="flex flex-col rounded-2xl border border-white/5 bg-white/[0.03] p-8 transition-colors hover:border-indigo-500/30">
              <!-- title -->
              <h3 class="mb-3 text-xl font-semibold text-white">{project.title}</h3>

              <!-- description -->
              <p class="mb-4 text-sm leading-relaxed text-gray-400">{project.description}</p>

              <!-- outcome callout -->
              <div class="mb-6 rounded-lg border border-green-500/20 bg-green-500/5 px-4 py-3">
                <p class="text-xs font-medium text-green-400">Result</p>
                <p class="mt-0.5 text-sm text-gray-300">{project.outcome}</p>
              </div>

              <!-- stack badges -->
              <div class="mt-auto flex flex-wrap gap-2">
                {project.stack.map((tech) => (
                  <span class="rounded-md border border-white/5 bg-white/5 px-2.5 py-1 text-xs text-gray-400">
                    {tech}
                  </span>
                ))}
              </div>

              <!-- links -->
              <div class="mt-6 flex gap-4 border-t border-white/5 pt-6 text-sm">
                {project.github && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-gray-400 transition-colors hover:text-white"
                  >
                    GitHub →
                  </a>
                )}
                {project.live && (
                  <a
                    href={project.live}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-indigo-400 transition-colors hover:text-indigo-300"
                  >
                    Live site →
                  </a>
                )}
              </div>
            </article>
          ))
      }
    </div>

    <!-- view all -->
    <div class="mt-12 text-center">
      <a
        href="https://github.com/Alseals1"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-gray-400 transition-colors hover:text-white"
      >
        View all on GitHub →
      </a>
    </div>
  </div>
</section>
